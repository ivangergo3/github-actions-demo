{
  "name": "github-actions-demo",
  "private": true,
  "version": "0.1.0",
  "description": "Demo repo for GitHub Actions parallel Playwright jobs + artifacts + PR comment.",
  "scripts": {
    "pw:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --ui",
    "test:e2e:report": "PLAYWRIGHT_BROWSERS_PATH=0 playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
